  <diagram id="NtPw0OAW-5gn6RQwfaho" name="B-Entra Log Pipeline (Diagnostics)">
    <mxGraphModel dx="1826" dy="1250" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="g3N0wBRVrjKoz22rJ95I-13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="g3N0wBRVrjKoz22rJ95I-1" target="g3N0wBRVrjKoz22rJ95I-3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="g3N0wBRVrjKoz22rJ95I-1" target="g3N0wBRVrjKoz22rJ95I-4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="g3N0wBRVrjKoz22rJ95I-1" target="g3N0wBRVrjKoz22rJ95I-5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <UserObject label="&lt;h2 class=&quot;text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold&quot;&gt;The Three Log Types&lt;/h2&gt;" id="g3N0wBRVrjKoz22rJ95I-1">
          <mxCell style="text;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;" parent="1" vertex="1">
            <mxGeometry y="-140" width="140" height="70" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;b&gt;Sign-in logs&lt;/b&gt; —&amp;nbsp;&lt;div&gt;record every authentication attempt. Every time a user tries to log into any app, a sign-in log entry is created. It tells you: who tried to sign in, from where, from what device, which CA policies applied, whether MFA was satisfied, and whether access was granted or blocked with which error code. This is the first log you check when a user says &quot;I can&#39;t get in.&quot;&lt;/div&gt;" link="Sign-in logs — record every authentication attempt. Every time a user tries to log into any app, a sign-in log entry is created. It tells you: who tried to sign in, from where, from what device, which CA policies applied, whether MFA was satisfied, and whether access was granted or blocked with which error code. This is the first log you check when a user says &quot;I can&#39;t get in.&quot;&#xa;&#xa;&#xa;Audit logs — record every configuration change made to the tenant. Someone assigned a new role, a CA policy was modified, a user was created, a group membership changed — all of that lands in the audit log with a timestamp, the actor who made the change, and what changed. This is the log you check when something is broken and you need to know what changed and who changed it.&#xa;&#xa;&#xa;Provisioning logs — record every sync event from Entra Connect. When a user syncs from yearwood.local to Entra, when an attribute updates, when a sync fails — all of that is captured here. This is the log you check when a user exists in AD but isn&#39;t showing up in Entra, or when their attributes aren&#39;t matching." id="g3N0wBRVrjKoz22rJ95I-3">
          <mxCell style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
            <mxGeometry x="200" y="-250" width="480" height="90" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;b&gt;Audit logs&lt;/b&gt; —&amp;nbsp;&lt;div&gt;record every configuration change made to the tenant. Someone assigned a new role, a CA policy was modified, a user was created, a group membership changed — all of that lands in the audit log with a timestamp, the actor who made the change, and what changed. This is the log you check when something is broken and you need to know what changed and who changed it.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" link="Sign-in logs — record every authentication attempt. Every time a user tries to log into any app, a sign-in log entry is created. It tells you: who tried to sign in, from where, from what device, which CA policies applied, whether MFA was satisfied, and whether access was granted or blocked with which error code. This is the first log you check when a user says &quot;I can&#39;t get in.&quot;&#xa;&#xa;&#xa;Audit logs — record every configuration change made to the tenant. Someone assigned a new role, a CA policy was modified, a user was created, a group membership changed — all of that lands in the audit log with a timestamp, the actor who made the change, and what changed. This is the log you check when something is broken and you need to know what changed and who changed it.&#xa;&#xa;&#xa;Provisioning logs — record every sync event from Entra Connect. When a user syncs from yearwood.local to Entra, when an attribute updates, when a sync fails — all of that is captured here. This is the log you check when a user exists in AD but isn&#39;t showing up in Entra, or when their attributes aren&#39;t matching." id="g3N0wBRVrjKoz22rJ95I-4">
          <mxCell style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
            <mxGeometry x="200" y="-130" width="480" height="90" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="&lt;div&gt;&lt;b&gt;Provisioning logs&lt;/b&gt; —&amp;nbsp;&lt;/div&gt;&lt;div&gt;record every sync event from Entra Connect. When a user syncs from yearwood.local to Entra, when an attribute updates, when a sync fails — all of that is captured here. This is the log you check when a user exists in AD but isn&#39;t showing up in Entra, or when their attributes aren&#39;t matching.&lt;/div&gt;" link="Sign-in logs — record every authentication attempt. Every time a user tries to log into any app, a sign-in log entry is created. It tells you: who tried to sign in, from where, from what device, which CA policies applied, whether MFA was satisfied, and whether access was granted or blocked with which error code. This is the first log you check when a user says &quot;I can&#39;t get in.&quot;&#xa;&#xa;&#xa;Audit logs — record every configuration change made to the tenant. Someone assigned a new role, a CA policy was modified, a user was created, a group membership changed — all of that lands in the audit log with a timestamp, the actor who made the change, and what changed. This is the log you check when something is broken and you need to know what changed and who changed it.&#xa;&#xa;&#xa;Provisioning logs — record every sync event from Entra Connect. When a user syncs from yearwood.local to Entra, when an attribute updates, when a sync fails — all of that is captured here. This is the log you check when a user exists in AD but isn&#39;t showing up in Entra, or when their attributes aren&#39;t matching." id="g3N0wBRVrjKoz22rJ95I-5">
          <mxCell style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
            <mxGeometry x="200" y="-10" width="480" height="90" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="g3N0wBRVrjKoz22rJ95I-6" target="g3N0wBRVrjKoz22rJ95I-8" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="g3N0wBRVrjKoz22rJ95I-6" target="g3N0wBRVrjKoz22rJ95I-10" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-6" value="&lt;h2 class=&quot;text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold&quot;&gt;The Two Query Surfaces&lt;br&gt;&lt;/h2&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry y="100" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-8" value="&lt;b&gt;Log Analytics / KQL&lt;/b&gt; —&amp;nbsp;&lt;div&gt;if you configure Entra to export logs to a Log Analytics workspace in Azure, you can query them using Kusto Query Language. This is the enterprise-grade path — it enables alerting, dashboards, long-term retention, and correlation across multiple log sources.&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="200" y="95" width="480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-10" value="&lt;b&gt;Microsoft Graph API &lt;/b&gt;—&amp;nbsp;&lt;div&gt;you can query logs directly from Entra without Log Analytics using Graph endpoints. Sign-in logs live at /auditLogs/signIns, audit logs at /auditLogs/directoryAudits, provisioning logs at /auditLogs/provisioning. This is the path you use for scripted exports, one-off investigations, and portfolio evidence collection.&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="200" y="200" width="480" height="80" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-16" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="-180" y="350" width="1200" height="572" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-18" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="-180" y="800" width="1200" height="834" as="geometry" />
        </mxCell>
        <mxCell id="g3N0wBRVrjKoz22rJ95I-19" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="-170" y="340" width="1200" height="450" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
