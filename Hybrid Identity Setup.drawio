        <mxCell id="Y1ChQ-webkH3Ca39AiPh-4" value="is a mid-sized robotics research company in&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Zürich&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Switzerland&lt;/span&gt;&amp;nbsp;with two locations.&lt;div&gt;a main campus and a remote engineering satellite.&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;" parent="Wo3be_J4C2kRciJHYnmH-2" vertex="1">
          <mxGeometry y="300" width="660" height="30" as="geometry" />
        </mxCell>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-3" value="SSO LABs" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;container=0;" parent="Wo3be_J4C2kRciJHYnmH-2" vertex="1">
          <mxGeometry x="235" y="220" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-5" value="They build autonomous systems for industrial and defense applications. The identity environment reflects a org that handles sensitive IP and has a mix of full-time researchers, engineers, and short-term contract specialists brought in for specific projects." style="text;whiteSpace=wrap;html=1;align=center;fontSize=20;container=0;" parent="Wo3be_J4C2kRciJHYnmH-2" vertex="1">
          <mxGeometry x="55" y="360" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-7" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;container=0;" parent="Wo3be_J4C2kRciJHYnmH-2" vertex="1">
          <mxGeometry x="55" width="550" height="244.29" as="geometry" />
        </mxCell>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-35" value="" style="whiteSpace=wrap;html=1;shape=mxgraph.basic.document;fillColor=light-dark(#faf9f5, #ededed);" parent="1" vertex="1">
          <mxGeometry x="1310" y="550" width="640" height="470" as="geometry" />
        </mxCell>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-36" value="Policy Intent Map" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=21;" parent="1" vertex="1">
          <mxGeometry x="1330" y="560" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-37" value="&lt;strong&gt;ResearchHub&lt;/strong&gt; — an internal web portal built by SSO Labs&#39; IT team where researchers log in to access project data, documents, and AI tools.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Since SSO Labs built it themselves, they get to use modern OIDC with a proper app registration in Entra.&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="780" y="940" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-38" value="&lt;strong&gt;RoboFleet Portal&lt;/strong&gt; — a fictional SaaS platform SSO Labs subscribes to for managing their autonomous robot fleets in the field.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;In real life this would be something like ServiceNow or Salesforce.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;S&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;AML is used because it&#39;s a third-party cloud app that SSO Labs doesn&#39;t control — the vendor defines the SP metadata.&lt;/span&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="560" y="940" width="150" height="80" as="geometry" />
        </mxCell>
        <UserObject label="&lt;strong&gt;LabOps Console&lt;/strong&gt; — a legacy on-prem system that runs on a server inside &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;yearwood.local&lt;/code&gt; and &lt;u&gt;controls lab equipment scheduling.&lt;/u&gt;&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;It has no cloud auth capability at all. Application Proxy solves this without requiring a VPN.&lt;/div&gt;" id="Y1ChQ-webkH3Ca39AiPh-40">
          <mxCell style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
            <mxGeometry x="990" y="940" width="170" height="70" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="Y1ChQ-webkH3Ca39AiPh-41" value="This represents the translation from business intent to technical enforcement" style="text;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="1330" y="590" width="420" height="40" as="geometry" />
        </mxCell>
